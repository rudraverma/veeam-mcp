# CyberHawk Veeam MCP — configuration
# Copy this file to .env and fill in real values. NEVER commit your real .env.

# ── Connection ──────────────────────────────────────────────────────────────
# Where Veeam Backup & Replication is reachable. On the VBR server itself this is
# localhost; point it at your VBR host/IP when running the MCP elsewhere.
VEEAM_HOST=localhost
VEEAM_PORT=9419

# Optional: full base URL override (wins over VEEAM_HOST/VEEAM_PORT). Use behind a proxy.
# VEEAM_BASE_URL=https://vbr.internal.example.com:9419

# ── Authentication ──────────────────────────────────────────────────────────
# A Windows account that can log into the Veeam console. A dedicated service account
# (e.g. svc-claude) with a Veeam role is strongly recommended over a personal admin.
VEEAM_USERNAME=
VEEAM_PASSWORD=

# ── API version ─────────────────────────────────────────────────────────────
# Starting guess for the required x-api-version header. The server auto-detects the
# correct value across VBR builds, so you rarely need to change this.
#   VBR 12.0 -> 1.1-rev0   |   VBR 12.1 -> 1.1-rev1
#   VBR 12.1.x -> 1.1-rev2 |   VBR 12.2 -> 1.2-rev0   |   VBR 12.3 -> 1.2-rev1
VEEAM_API_VERSION=1.1-rev1

# ── Behaviour ───────────────────────────────────────────────────────────────
# VBR ships a self-signed certificate by default, so accept it unless you installed a trusted cert.
VEEAM_ACCEPT_SELF_SIGNED=true

# Safety switch. true = block ALL state-changing tools (start/stop/create/delete/restore),
# allowing only read operations. Set false for full operator control.
VEEAM_READONLY=false

# Request timeout in milliseconds.
VEEAM_TIMEOUT_MS=60000
